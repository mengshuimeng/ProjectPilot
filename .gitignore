# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest_tmp/
manual_test_temp/
test_temp_work/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment and secrets
.env
.env.*
!.env.example

# Streamlit local runtime logs
.streamlit-*.out
.streamlit-*.err

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/

# ProjectPilot runtime data
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/sessions/*
!data/sessions/.gitkeep
outputs/*
!outputs/.gitkeep

# Temporary conversion files
*.tmp
*.temp
~$*
